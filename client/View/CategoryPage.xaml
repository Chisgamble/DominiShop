<Page
    x:Class="DominiShop.View.CategoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:model="using:DominiShop.Model"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:conv="using:DominiShop.Converter"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />
    </Page.Resources>

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="15" VerticalAlignment="Center" HorizontalAlignment="Left">
                <TextBlock Text="Product Categories" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>

                <AutoSuggestBox PlaceholderText="Search categories..." QueryIcon="Find" Width="280" Height="36" VerticalAlignment="Center"
                                Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <ComboBox ItemsSource="{x:Bind ViewModel.SortOptions}" 
                          SelectedItem="{x:Bind ViewModel.SelectedSortOption, Mode=TwoWay}" 
                          Width="180" Height="36" VerticalAlignment="Center" PlaceholderText="Sort by"/>
            </StackPanel>

            <Button Grid.Column="1" HorizontalAlignment="Right" 
                    Style="{StaticResource AccentButtonStyle}" 
                    VerticalAlignment="Center" 
                    Height="36"
                    Padding="12,0"
                    Click="OnAddNewClick">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE710;" FontSize="14"/>
                    <TextBlock Text="Add New"/>
                </StackPanel>
            </Button>
        </Grid>

        <controls:DataGrid 
            Grid.Row="1"
            ItemsSource="{x:Bind ViewModel.FilteredCategories, Mode=OneWay}"
            SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
            SelectionChanged="OnRowSelected"
            AutoGenerateColumns="False"
            GridLinesVisibility="Horizontal"
            IsReadOnly="True"
            SelectionMode="Single"
            CanUserSortColumns="True"
            RowHeight="52"
            HorizontalAlignment="Stretch">

            <controls:DataGrid.Columns>
                <controls:DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70"/>

                <controls:DataGridTemplateColumn Header="Category Name" Width="2*">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="model:Category">
                            <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="12,0"/>
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>

                <controls:DataGridTemplateColumn Header="Description" Width="3*">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="model:Category">
                            <TextBlock Text="{x:Bind Note}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="12,0" ToolTipService.ToolTip="{x:Bind Note}"/>
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>

                <controls:DataGridTemplateColumn Header="Items Count" Width="120">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="model:Category">
                            <TextBlock Text="{x:Bind ProductCount}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>
            </controls:DataGrid.Columns>
        </controls:DataGrid>

        <ContentDialog x:Name="DetailDialog" 
                       Title="Category Details"
                       PrimaryButtonText="Edit" 
                       SecondaryButtonText="Delete"
                       CloseButtonText="Close"
                       DefaultButton="Primary">
            <StackPanel Spacing="12" Margin="0,10,0,0" Width="350">
                <TextBlock Text="Category Name" Foreground="Gray" FontSize="12"/>
                <TextBlock Text="{x:Bind ViewModel.SelectedCategory.Name, Mode=OneWay}" FontSize="18" FontWeight="Bold" TextWrapping="Wrap"/>

                <TextBlock Text="Description" Foreground="Gray" FontSize="12" Margin="0,10,0,0"/>
                <TextBlock Text="{x:Bind ViewModel.SelectedCategory.Note, Mode=OneWay}" TextWrapping="Wrap"/>

                <TextBlock Text="Total Products" Foreground="Gray" FontSize="12" Margin="0,10,0,0"/>
                <TextBlock Text="{x:Bind ViewModel.SelectedCategory.ProductCount, Mode=OneWay}" FontSize="16"/>
            </StackPanel>
        </ContentDialog>

        <ContentDialog x:Name="EditDialog" 
                       Title="{x:Bind GetDialogTitle(ViewModel.IsEditMode), Mode=OneWay}"
                       PrimaryButtonText="Save Changes" 
                       CloseButtonText="Cancel"
                       DefaultButton="Primary"
                       PrimaryButtonClick="OnSaveDialogClick">
            <StackPanel Spacing="15" Margin="0,10,0,0" Width="350">
                <TextBox Header="Category Name" PlaceholderText="e.g. Electronics"
                         Text="{x:Bind ViewModel.EditingCategory.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBox Header="Description" PlaceholderText="Enter category details..." 
                         Text="{x:Bind ViewModel.EditingCategory.Note, Mode=TwoWay}" 
                         Height="80" TextWrapping="Wrap" AcceptsReturn="True"/>
            </StackPanel>
        </ContentDialog>

    </Grid>
</Page>