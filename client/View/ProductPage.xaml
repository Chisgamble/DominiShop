<Page
    x:Class="DominiShop.View.ProductPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:model="using:DominiShop.Model"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" ColumnSpacing="15" Margin="0,0,20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Products Inventory" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" />

                <AutoSuggestBox Grid.Column="1" PlaceholderText="Search products..." QueryIcon="Find" Height="36" VerticalAlignment="Center"
                                Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <ComboBox Grid.Column="2" ItemsSource="{x:Bind ViewModel.FilterCategories}" 
                          SelectedItem="{x:Bind ViewModel.SelectedFilterCategory, Mode=TwoWay}"
                          DisplayMemberPath="Name" Width="160" Height="36" VerticalAlignment="Center" PlaceholderText="All Categories"/>

                <ComboBox Grid.Column="3" ItemsSource="{x:Bind ViewModel.SortOptions}" 
                          SelectedItem="{x:Bind ViewModel.SelectedSortOption, Mode=TwoWay}" 
                          Width="150" Height="36" VerticalAlignment="Center" PlaceholderText="Sort by"/>
            </Grid>

            <Button Grid.Column="1" HorizontalAlignment="Right" Style="{StaticResource AccentButtonStyle}" 
                    VerticalAlignment="Center" Height="36" Padding="12,0" Click="OnAddNewClick">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE710;" FontSize="14"/>
                    <TextBlock Text="Add New"/>
                </StackPanel>
            </Button>
        </Grid>

        <controls:DataGrid 
            Grid.Row="1"
            ItemsSource="{x:Bind ViewModel.FilteredProducts, Mode=OneWay}"
            SelectedItem="{x:Bind ViewModel.SelectedProduct, Mode=TwoWay}"
            SelectionChanged="OnRowSelected"
            AutoGenerateColumns="False" GridLinesVisibility="Horizontal" IsReadOnly="True" SelectionMode="Single"
            CanUserSortColumns="True" RowHeight="52" HorizontalAlignment="Stretch">

            <controls:DataGrid.Columns>
                <controls:DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70"/>
                <controls:DataGridTemplateColumn Header="Product Name" Width="3*">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="model:Product">
                            <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="12,0"/>
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>
                <controls:DataGridTextColumn Header="Category" Binding="{Binding CategoryName}" Width="2*"/>
                <controls:DataGridTextColumn Header="Base Price" Binding="{Binding FormattedBasePrice}" Width="1.5*"/>
                <controls:DataGridTextColumn Header="Sell Price" Binding="{Binding FormattedPrice}" Width="1.5*"/>
                <controls:DataGridTextColumn Header="In Stock" Binding="{Binding Quantity}" Width="100"/>
                <controls:DataGridTextColumn Header="Sold" Binding="{Binding Sold}" Width="100"/>
            </controls:DataGrid.Columns>
        </controls:DataGrid>

        <ContentDialog x:Name="DetailDialog" Title="Product Details" PrimaryButtonText="Edit" SecondaryButtonText="Delete" CloseButtonText="Close" DefaultButton="Primary">
            <StackPanel Spacing="16" Margin="0,10,0,0" Width="400">
                <StackPanel>
                    <TextBlock Text="Product Name" Foreground="Gray" FontSize="12"/>
                    <TextBlock Text="{x:Bind ViewModel.SelectedProduct.Name, Mode=OneWay}" FontSize="20" FontWeight="Bold" TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Category" Foreground="Gray" FontSize="12"/>
                    <TextBlock Text="{x:Bind ViewModel.SelectedProduct.CategoryName, Mode=OneWay}" FontSize="16" TextWrapping="Wrap" FontWeight="SemiBold"/>
                </StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="In Stock" Foreground="Gray" FontSize="12"/>
                        <TextBlock Text="{x:Bind ViewModel.SelectedProduct.Quantity, Mode=OneWay}" FontSize="16" FontWeight="Bold" Foreground="{ThemeResource SystemAccentColor}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Base Price" Foreground="Gray" FontSize="12"/>
                        <TextBlock Text="{x:Bind ViewModel.SelectedProduct.FormattedBasePrice, Mode=OneWay}" FontSize="16"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Sell Price" Foreground="Gray" FontSize="12"/>
                        <TextBlock Text="{x:Bind ViewModel.SelectedProduct.FormattedPrice, Mode=OneWay}" FontSize="16" FontWeight="Bold" Foreground="Green"/>
                    </StackPanel>
                </Grid>
                <StackPanel>
                    <TextBlock Text="Note" Foreground="Gray" FontSize="12"/>
                    <TextBlock Text="{x:Bind ViewModel.SelectedProduct.Note, Mode=OneWay}" TextWrapping="Wrap"/>
                </StackPanel>
            </StackPanel>
        </ContentDialog>

        <ContentDialog x:Name="EditDialog" Title="{x:Bind GetDialogTitle(ViewModel.IsEditMode), Mode=OneWay}"
                       PrimaryButtonText="Save Changes" CloseButtonText="Cancel" DefaultButton="Primary" PrimaryButtonClick="OnSaveDialogClick">

            <ScrollViewer VerticalScrollBarVisibility="Auto" Width="420" MaxHeight="550">

                <StackPanel Spacing="15" Margin="0,10,16,10">

                    <InfoBar x:Name="ErrorBanner" IsOpen="False" Severity="Error" Title="Invalid Input" IsClosable="False" Margin="0,0,0,5"/>

                    <TextBox Header="Product Name" Text="{x:Bind ViewModel.EditingProduct.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <ComboBox Header="Category (Required)" ItemsSource="{x:Bind ViewModel.AvailableCategories}" 
                              SelectedValue="{x:Bind ViewModel.EditingProduct.CategoryId, Mode=TwoWay}" 
                              SelectedValuePath="Id" DisplayMemberPath="Name" HorizontalAlignment="Stretch"/>

                    <Grid ColumnSpacing="15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <NumberBox Grid.Column="0" Header="Base Price" Minimum="0" Value="{x:Bind ViewModel.EditingBasePrice, Mode=TwoWay}" SpinButtonPlacementMode="Hidden" />
                        <NumberBox Grid.Column="1" Header="Sell Price" Minimum="0" Value="{x:Bind ViewModel.EditingSellPrice, Mode=TwoWay}" SpinButtonPlacementMode="Hidden" />
                    </Grid>

                    <TextBlock Text="Inventory Management" FontWeight="SemiBold" Margin="0,5,0,-5"/>
                    <Grid ColumnSpacing="15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <NumberBox Grid.Column="0" Header="In Stock" Minimum="0" Value="{x:Bind ViewModel.EditingInStock, Mode=TwoWay}" SpinButtonPlacementMode="Inline" SmallChange="1" />
                        <NumberBox Grid.Column="1" Header="Sold" Minimum="0" Value="{x:Bind ViewModel.EditingSold, Mode=TwoWay}" SpinButtonPlacementMode="Inline" SmallChange="1" />
                    </Grid>

                    <NumberBox Header="Required Total (Quantity)" Value="{x:Bind ViewModel.EditingTotalQuantity, Mode=TwoWay}" Minimum="0" SpinButtonPlacementMode="Inline" SmallChange="1"/>

                    <TextBox Header="Note" Text="{x:Bind ViewModel.EditingProduct.Note, Mode=TwoWay}" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>

                </StackPanel>
            </ScrollViewer>
        </ContentDialog>
    </Grid>
</Page>