<Page
    x:Class="DominiShop.View.VoucherPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:model="using:DominiShop.Model"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:conv="using:DominiShop.Converter"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <conv:BoolToVisibilityConverter        x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
    </Page.Resources>

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header row -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left: title + search + filters -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">

                <TextBlock Text="Vouchers" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0"/>

                <AutoSuggestBox PlaceholderText="Search code or type…"
                                QueryIcon="Find"
                                Width="240" Height="36"
                                VerticalAlignment="Center"
                                Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <ComboBox ItemsSource="{x:Bind ViewModel.StatusFilters}"
                          SelectedItem="{x:Bind ViewModel.SelectedStatusFilter, Mode=TwoWay}"
                          Width="130" Height="36" VerticalAlignment="Center"
                          PlaceholderText="Status"/>

                <ComboBox ItemsSource="{x:Bind ViewModel.SortOptions}"
                          SelectedItem="{x:Bind ViewModel.SelectedSortOption, Mode=TwoWay}"
                          Width="190" Height="36" VerticalAlignment="Center"
                          PlaceholderText="Sort by"/>
            </StackPanel>

            <!-- Right: Add New button -->
            <Button Grid.Column="1"
                    Style="{StaticResource AccentButtonStyle}"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Height="36" Padding="12,0"
                    Click="OnAddNewClick">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE710;" FontSize="14"/>
                    <TextBlock Text="Add"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- DataGrid -->
        <controls:DataGrid
            Grid.Row="1"
            ItemsSource="{x:Bind ViewModel.FilteredVouchers, Mode=OneWay}"
            SelectedItem="{x:Bind ViewModel.SelectedVoucher, Mode=TwoWay}"
            SelectionChanged="OnRowSelected"
            AutoGenerateColumns="False"
            GridLinesVisibility="Horizontal"
            IsReadOnly="True"
            SelectionMode="Single"
            CanUserSortColumns="True"
            RowHeight="52"
            HorizontalAlignment="Stretch">

            <controls:DataGrid.Columns>

                <!-- ID -->
                <controls:DataGridTextColumn Header="ID"
                                             Binding="{Binding Id}"
                                             Width="60"/>

                <!-- Code -->
                <controls:DataGridTemplateColumn Header="Code" Width="1.5*">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="model:Voucher">
                            <TextBlock Text="{x:Bind Code}"
                                       FontWeight="SemiBold"
                                       FontFamily="Consolas"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"
                                       Margin="12,0"/>
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>

                <!-- Type -->
                <controls:DataGridTemplateColumn Header="Type" Width="130">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="model:Voucher">
                            <TextBlock Text="{x:Bind DisplayType}"
                                       VerticalAlignment="Center"
                                       Margin="12,0"/>
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>

                <!-- Discount -->
                <controls:DataGridTemplateColumn Header="Discount" Width="130">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="model:Voucher">
                            <TextBlock Text="{x:Bind DisplayDiscount}"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource SystemAccentColor}"
                                       VerticalAlignment="Center"
                                       Margin="12,0"/>
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>

                <!-- Max per person -->
                <controls:DataGridTemplateColumn Header="Max / Person" Width="120">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="model:Voucher">
                            <TextBlock VerticalAlignment="Center" Margin="12,0">
                                <Run Text="{x:Bind MaxPerPerson}"/>
                            </TextBlock>
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>

                <!-- Expiry -->
                <controls:DataGridTemplateColumn Header="Expiry" Width="130">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="model:Voucher">
                            <TextBlock Text="{x:Bind DisplayExpiry}"
                                       VerticalAlignment="Center"
                                       Margin="12,0"/>
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>

                <!-- Status badge -->
                <controls:DataGridTemplateColumn Header="Status" Width="110">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="model:Voucher">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                                <!-- Active -->
                                <Border CornerRadius="4" Padding="8,3"
                                        Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
                                        Visibility="{x:Bind IsActive, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Active" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                                </Border>
                                <!-- Inactive -->
                                <Border CornerRadius="4" Padding="8,3"
                                        Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
                                        Visibility="{x:Bind IsActive, Converter={StaticResource InvBoolToVis}}">
                                    <TextBlock Text="Inactive" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>

                <!-- Inline delete -->
                <controls:DataGridTemplateColumn Header="" Width="50">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="model:Voucher">
                            <Button Background="Transparent"
                                    BorderThickness="0"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Click="OnDeleteRowClick"
                                    ToolTipService.ToolTip="Delete">
                                <FontIcon Glyph="&#xE74D;" FontSize="14"
                                          Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                            </Button>
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>

            </controls:DataGrid.Columns>
        </controls:DataGrid>

        <!-- Detail dialog -->
        <ContentDialog x:Name="DetailDialog"
                       Title="Voucher Details"
                       PrimaryButtonText="Edit"
                       SecondaryButtonText="Delete"
                       CloseButtonText="Close"
                       DefaultButton="Primary">
            <StackPanel Spacing="14" Margin="0,10,0,0" Width="360">

                <StackPanel>
                    <TextBlock Text="Code" Foreground="Gray" FontSize="12"/>
                    <TextBlock Text="{x:Bind ViewModel.SelectedVoucher.Code, Mode=OneWay}"
                               FontSize="22" FontWeight="Bold" FontFamily="Consolas"/>
                </StackPanel>

                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Type" Foreground="Gray" FontSize="12"/>
                        <TextBlock Text="{x:Bind ViewModel.SelectedVoucher.DisplayType, Mode=OneWay}" FontSize="15"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Discount" Foreground="Gray" FontSize="12"/>
                        <TextBlock Text="{x:Bind ViewModel.SelectedVoucher.DisplayDiscount, Mode=OneWay}"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="{ThemeResource SystemAccentColor}"/>
                    </StackPanel>
                </Grid>

                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Max Uses / Person" Foreground="Gray" FontSize="12"/>
                        <TextBlock Text="{x:Bind ViewModel.SelectedVoucher.MaxPerPerson, Mode=OneWay}"
                                   FontSize="15"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Expiry Date" Foreground="Gray" FontSize="12"/>
                        <TextBlock Text="{x:Bind ViewModel.SelectedVoucher.DisplayExpiry, Mode=OneWay}"
                                   FontSize="15"/>
                    </StackPanel>
                </Grid>

                <StackPanel>
                    <TextBlock Text="Status" Foreground="Gray" FontSize="12"/>
                    <TextBlock Text="{x:Bind ViewModel.SelectedVoucher.StatusLabel, Mode=OneWay}"
                               FontSize="15" FontWeight="SemiBold"/>
                </StackPanel>

            </StackPanel>
        </ContentDialog>

        <!-- Edit / Create dialog -->
        <ContentDialog x:Name="EditDialog"
                       Title="{x:Bind GetDialogTitle(ViewModel.IsEditMode), Mode=OneWay}"
                       PrimaryButtonText="Save Changes"
                       CloseButtonText="Cancel"
                       DefaultButton="Primary"
                       PrimaryButtonClick="OnSaveDialogClick">

            <ScrollViewer VerticalScrollBarVisibility="Auto" Width="400" MaxHeight="540">
                <StackPanel Spacing="16" Margin="0,10,16,10">

                    <InfoBar x:Name="ErrorBanner"
                             IsOpen="False"
                             Severity="Error"
                             IsClosable="False"
                             Margin="0,0,0,4"/>

                    <!-- Code -->
                    <TextBox Header="Voucher Code *"
                             PlaceholderText="e.g. SUMMER25"
                             CharacterCasing="Upper"
                             Text="{x:Bind ViewModel.EditingVoucher.Code, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Type -->
                    <ComboBox Header="Discount Type *"
                              HorizontalAlignment="Stretch"
                              PlaceholderText="Select a discount type"
                              SelectedIndex="{x:Bind ViewModel.EditingTypeIndex, Mode=TwoWay}">
                        <ComboBoxItem Content="Percent (%)"/>
                        <ComboBoxItem Content="Fixed amount (VNĐ)"/>
                        <ComboBoxItem Content="Free Shipping"/>
                    </ComboBox>

                    <!-- Percent / amount -->
                    <NumberBox Header="Discount Value (0–100 for percent)"
                               Minimum="0" Maximum="100"
                               Value="{x:Bind ViewModel.EditingPercent, Mode=TwoWay}"
                               SpinButtonPlacementMode="Hidden"
                               PlaceholderText="Enter discount amount"/>

                    <!-- Max per person -->
                    <NumberBox Header="Max Uses per Person (0 = unlimited)"
                               Minimum="0"
                               Value="{x:Bind ViewModel.EditingMaxPerPerson, Mode=TwoWay}"
                               SpinButtonPlacementMode="Inline"
                               SmallChange="1"/>

                    <!-- Expiry date -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Expiry Date" Style="{ThemeResource CaptionTextBlockStyle}"/>
                        <CalendarDatePicker PlaceholderText="Select expiry date (optional)"
                                            HorizontalAlignment="Stretch"
                                            Date="{x:Bind ViewModel.EditingExpiryDate, Mode=TwoWay}"/>
                    </StackPanel>

                    <!-- Active toggle (edit mode only) -->
                    <ToggleSwitch Header="Active"
                                  IsOn="{x:Bind ViewModel.EditingIsActive, Mode=TwoWay}"
                                  OnContent="Yes" OffContent="No"
                                  Visibility="{x:Bind ViewModel.IsEditMode, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>

                </StackPanel>
            </ScrollViewer>
        </ContentDialog>

    </Grid>
</Page>
